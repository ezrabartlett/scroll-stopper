{
  "name": "Scroll Stopper",
  "description": "Block distracting sites and enforce deep focus mode",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["storage", "webNavigation", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "edit-list.html", "styles.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
